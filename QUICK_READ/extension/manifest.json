{
  "manifest_version": 3,
  "name": "QuickRead",
  "version": "1.5.11",
  "description": "Summarize web page using Gemini",
  "default_locale": "en",
  "icons": {
    "128": "img/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+G"
      }
    }
  }
}